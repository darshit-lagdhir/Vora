# ═══════════════════════════════════════════════════════════════════════════════
# Project VORA — Environment Configuration Template
# Copy this file to .env and populate with your actual values
# NEVER commit the .env file to version control
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Network Configuration ────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
# NODE_ENV=production  (uncomment for production deployment)

# ─── Database Access (Supabase PostgreSQL) ────────────────────────────────────
DATABASE_URL=postgresql://username:password@db.project-ref.supabase.co:5432/postgres

# ─── Cryptographic Token Secret (JWT Signing Key) ─────────────────────────────
# MUST be a high-entropy, random string (min 64 chars recommended)
JWT_SECRET=your-jwt-secret-cryptographic-salt-key

# ─── CORS Domain Whitelist ────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Development default: http://localhost:5173,http://127.0.0.1:5173
# Production example: https://vora.vercel.app,https://www.vora.app
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ─── Frontend Build Environment (Vite expects VITE_ prefix) ──────────────────
# Local development:
VITE_API_URL=http://localhost:5000
# Production example:
# VITE_API_URL=https://vora-api.onrender.com

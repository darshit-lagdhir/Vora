{
  "name": "project-vora",
  "version": "1.0.0",
  "description": "Unified package configuration for Project Vora",
  "type": "module",
  "scripts": {
    "prestart": "node vora-backend/src/scripts/killPort.js",
    "start": "npm run build && node vora-backend/src/index.js",
    "predev": "node vora-backend/src/scripts/killPort.js",
    "dev": "npm run build && node vora-backend/src/index.js",
    "predev:single": "node vora-backend/src/scripts/killPort.js",
    "dev:single": "npm run build && node vora-backend/src/index.js",
    "predev:backend": "node vora-backend/src/scripts/killPort.js",
    "dev:backend": "nodemon vora-backend/src/index.js",
    "dev:frontend": "vite vora-frontend",
    "build": "vite build vora-frontend",
    "build:frontend": "vite build vora-frontend",
    "preview:frontend": "vite preview vora-frontend",
    "db:setup": "node vora-backend/src/scripts/setupDb.js",
    "db:seed": "node vora-backend/src/scripts/seedDb.js",
    "lint": "eslint . --ext .js,.jsx && prettier --check .",
    "test": "cross-env NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand --detectOpenHandles --forceExit",
    "test:coverage": "cross-env NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand --detectOpenHandles --forceExit --coverage"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "framer-motion": "^12.40.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.379.0",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "pg": "^8.12.0",
    "pino": "^10.3.1",
    "node-addon-api": "^8.0.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.1",
    "recharts": "^3.8.1",
    "redis": "^6.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.1",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^9.2.0",
    "nodemon": "^3.1.2",
    "postcss": "^8.4.38",
    "prettier": "^3.2.5",
    "supertest": "^7.0.0",
    "tailwindcss": "^3.4.3",
    "terser": "^5.48.0",
    "vite": "^5.2.11"
  },
  "jest": {
    "setupFilesAfterEnv": [
      "<rootDir>/vora-backend/tests/config/testSetup.js"
    ],
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "vora-backend/src/middleware/validation.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 90
      }
    }
  }
}
